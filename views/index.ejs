<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quickie | Shorten Links Fast</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="page-shell">
      <section class="hero-card">
        <div class="brand-row">
          <div class="brand-mark">Q</div>
          <div>
            <p class="eyebrow">Quickie</p>
            <h1>Short links, built for speed.</h1>
          </div>
        </div>

        <p class="hero-copy">
          Turn long URLs into clean, trackable links with a focused interface and
          live click analytics.
        </p>

        <form class="shorten-form" action="/url" method="post">
          <label for="url">Destination URL</label>
          <div class="input-row">
            <input
              id="url"
              name="url"
              type="url"
              placeholder="https://example.com/very/long/link"
              value="<%= originalUrl || '' %>"
              required
            />
            <button type="submit">Create link</button>
          </div>
        </form>

        <% if (error) { %>
          <div class="status status-error"><%= error %></div>
        <% } %>

        <div
          id="saved-link-slot"
          data-has-server-link="<%= shortUrl ? 'true' : 'false' %>"
          data-short-url="<%= shortUrl || '' %>"
          data-display-short-url="<%= displayShortUrl || '' %>"
          data-short-id="<%= shortId || '' %>"
        ></div>

        <% if (shortUrl) { %>
          <div class="status status-success">
                <div>
                  <span class="status-label">Your Quickie link</span>
                  <a href="<%= shortUrl %>" target="_blank" rel="noreferrer"><%= displayShortUrl %></a>
                </div>
                <div class="status-actions">
                  <a class="analytics-link" href="/url/analytics/<%= shortId %>">View analytics</a>
                  <button type="button" class="analytics-link new-quickie">New Quickie</button>
                </div>
          </div>
        <% } %>

        <div class="feature-grid">
          <article>
            <h2>Fast creation</h2>
            <p>Generate a compact branded link in one step.</p>
          </article>
          <article>
            <h2>Click tracking</h2>
            <p>Each redirect is logged with a timestamp for analytics.</p>
          </article>
          <article>
            <h2>Clean reporting</h2>
            <p>See total clicks and the full visit history in one place.</p>
          </article>
        </div>
      </section>
    </div>
    <script>
      (function () {
        const storageKey = "quickie:lastLink";
        const slot = document.getElementById("saved-link-slot");
        const hasServerLink = slot?.dataset.hasServerLink === "true";

        function saveLink(payload) {
          try {
            localStorage.setItem(storageKey, JSON.stringify(payload));
          } catch (error) {
            // Ignore storage failures and keep the page functional.
          }
        }

        // If the page was loaded via a manual reload, clear the saved link so
        // the Quickie link does not persist across refreshes.
        (function clearOnReload() {
          try {
            const navEntries = performance.getEntriesByType
              ? performance.getEntriesByType("navigation")
              : [];

            const navType = (navEntries && navEntries[0] && navEntries[0].type) ||
              (performance && performance.navigation && performance.navigation.type === 1 ? 'reload' : null);

            if (navType === 'reload') {
              localStorage.removeItem(storageKey);
            }
          } catch (e) {
            // Ignore — navigation timing may not be available in some browsers.
          }
        })();

        function loadLink() {
          try {
            const raw = localStorage.getItem(storageKey);
            return raw ? JSON.parse(raw) : null;
          } catch (error) {
            return null;
          }
        }

        function renderLink(payload) {
          if (!slot || !payload || !payload.shortUrl || !payload.displayShortUrl || !payload.shortId) {
            return;
          }

          slot.innerHTML = `
            <div class="status status-success">
              <div>
                <span class="status-label">Your Quickie link</span>
                <a href="${payload.shortUrl}" target="_blank" rel="noreferrer">${payload.displayShortUrl}</a>
              </div>
              <div class="status-actions">
                <a class="analytics-link" href="/url/analytics/${payload.shortId}">View analytics</a>
                <button type="button" class="analytics-link new-quickie">New Quickie</button>
              </div>
            </div>
          `;
        }

        if (hasServerLink) {
          saveLink({
            shortUrl: slot.dataset.shortUrl || "",
            displayShortUrl: slot.dataset.displayShortUrl || "",
            shortId: slot.dataset.shortId || "",
          });
        } else {
          renderLink(loadLink());
        }

        function clearSavedAndUI() {
          try { localStorage.removeItem(storageKey); } catch (e) {}
          if (slot) slot.innerHTML = '';
          const urlInput = document.getElementById('url');
          if (urlInput) urlInput.value = '';

          document.querySelectorAll('.status.status-success').forEach(el => {
            const label = el.querySelector('.status-label');
            if (label && label.textContent && label.textContent.trim() === 'Your Quickie link') {
              el.remove();
            }
          });
        }

        document.addEventListener('click', (e) => {
          const target = e.target;
          if (target && target.classList && target.classList.contains('new-quickie')) {
            clearSavedAndUI();
          }
        });
      })();
    </script>
  </body>
</html>